# ESP-IDF build artifacts
build/
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Python bytecode (from host-side tools/)
__pycache__/
*.pyc

# Compiled model artifacts (regenerated by training pipeline; not source)
models/*/tier0_mlc.ucf.tmp
models/*/*.tflite.tmp

# Local secrets (none expected, but defensive)
.env
*.pem
*.key

# WSL / Windows download artifacts
*:Zone.Identifier

# Local Claude Code settings (per-developer permissions)
.claude/settings.local.json
